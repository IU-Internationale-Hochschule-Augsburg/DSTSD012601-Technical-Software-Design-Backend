# App
APP_TAG=latest
APP_PORT=8080
ASPNETCORE_ENVIRONMENT=Production

# Datenbank
POSTGRES_DB=subscription_control
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme

# JWT – Signaturschlüssel für Access-Tokens (HS256, mind. 32 Zeichen). In Produktion zwingend ändern!
JWT_KEY=change-me-to-a-long-random-secret-min-32-chars

# CORS – erlaubte Origins (kommagetrennt), z. B. https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000